---
/**
 * Location hub page — one per city. Cross-links to every niche in that city.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { heroImage, cardImage } from '../../lib/images';
import { SIGNUP_URL, SIGNUP_REL, SIGNUP_TARGET } from '../../lib/config';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(loc => ({
    params: { location: loc.data.slug },
    props: { location: loc.data },
  }));
}

const { location } = Astro.props;
const niches = (await getCollection('niches')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---
<BaseLayout
  title={`Adult Dating in ${location.title}`}
  description={`Meet open-minded singles across ${location.title}. Niche-first matching, verified profiles, and active local communities on Kindred.`}
>
  <section class="hero hero--image" style={`background-image: linear-gradient(180deg, rgba(11,11,15,0.35), rgba(11,11,15,0.9)), url('${heroImage(`loc:${location.slug}`)}');`}>
    <div class="container">
      <p class="hero__tagline">{location.title}, {location.country}</p>
      <h1>Adult dating across {location.title}</h1>
      <p class="hero__lead">
        From {location.neighborhoods.slice(0, 3).join(', ')} and beyond, Kindred
        connects open-minded singles across {location.title} on their own terms.
        Niche-first matching, verified members, and active local community.
      </p>
      <div class="hero__actions">
        <a href={SIGNUP_URL} target={SIGNUP_TARGET} rel={SIGNUP_REL} class="btn btn--primary">Join free</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">What are you into?</p>
      <h2>Pick your niche in {location.title}</h2>
      <p class="muted" style="max-width: 640px;">
        Kindred runs niche-first communities across {location.title}. Pick the one
        that matches what you're actually looking for.
      </p>
      <div class="grid grid--3" style="margin-top: 28px;">
        {niches.map(niche => (
          <a href={`/${location.slug}/${niche.data.slug}/`} class="n-card">
            <div class="n-card__img" style={`background-image: url('${cardImage(`loc:${location.slug}:${niche.data.slug}`)}');`}></div>
            <div class="n-card__body">
              <span class="pill">{niche.data.title}</span>
              <h3 style="margin-top: 14px;">{niche.data.title} in {location.title}</h3>
              <p class="muted" style="margin: 0; font-size: 0.92rem;">{niche.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {location.neighborhoods?.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow">Across {location.title}</p>
        <h2>Where our {location.title} members are</h2>
        <p class="muted" style="max-width: 640px;">
          Kindred has active members across every neighbourhood in {location.title}.
          Here's where they are.
        </p>
        <div class="grid grid--4" style="margin-top: 28px;">
          {location.neighborhoods.map((n, i) => (
            <article class="n-card">
              <div class="n-card__img" style={`background-image: url('${cardImage(`loc:${location.slug}:n${i}`)}');`}></div>
              <div class="n-card__body">
                <strong style="color: var(--c-text);">{n}</strong>
                <p class="muted" style="margin: 4px 0 0; font-size: 0.88rem;">
                  Active Kindred members in {n}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {location.landmarks?.length > 0 && (
    <section class="section section--tight">
      <div class="container" style="max-width: 760px;">
        <p class="eyebrow">Local colour</p>
        <h2>Dating in {location.title}</h2>
        <p class="muted">
          {location.title}'s best date spots are the ones locals actually use.
          Whether it's drinks near {location.landmarks[0]}
          {location.landmarks[1] ? `, a walk around ${location.landmarks[1]}` : ''}
          {location.landmarks[2] ? `, or an evening near ${location.landmarks[2]}` : ''}
          &mdash; Kindred members know the spots.
        </p>
        <p class="muted">
          With a population of {location.population ? `around ${(location.population / 1000).toFixed(0)},000` : 'hundreds of thousands'} and active
          communities in {location.neighborhoods.slice(0, 4).join(', ')}, {location.title}
          has one of the most varied adult dating scenes in the UK.
        </p>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container" style="text-align: center; max-width: 620px;">
      <h2>Meet open-minded singles in {location.title}</h2>
      <p class="muted">Free to join, verified members only, active community.</p>
      <a href={SIGNUP_URL} target={SIGNUP_TARGET} rel={SIGNUP_REL} class="btn btn--primary" style="margin-top: 8px;">Create my profile</a>
      <p class="muted" style="margin-top: 14px; font-size: 0.8rem;">18+ only.</p>
    </div>
  </section>
</BaseLayout>
