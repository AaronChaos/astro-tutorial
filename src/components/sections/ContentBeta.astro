---
/** ContentBeta — `content_beta`. Same shape as alpha; image-left variant. */
import type { ContentBetaSection, WpImage, AcfColor } from '../../lib/wp';
interface Props { data: ContentBetaSection; }
const { data } = Astro.props;
const bgRaw = data.content_beta_background_colour;
const bg = typeof bgRaw === 'string' ? bgRaw : (bgRaw as AcfColor | undefined)?.color;
const img = data.content_beta_image as WpImage | null | undefined;
const imgUrl = img && typeof img === 'object' ? img.url : null;
const buttons = data.content_beta_cta_buttons ?? [];
---
<section class="section content-beta" style={bg ? `background: ${bg};` : undefined}>
  <div class="container content-beta__grid">
    {imgUrl && <img src={imgUrl} alt={(typeof img === 'object' && img?.alt) || ''} loading="lazy" class="content-beta__image" />}
    <div class="content-beta__text">
      {data.content_beta_heading && <h2>{data.content_beta_heading}</h2>}
      {data.content_beta_introduction && <p class="content-beta__intro">{data.content_beta_introduction}</p>}
      {data.content_beta_main_content && <p class="content-beta__body">{data.content_beta_main_content}</p>}
      {buttons.length > 0 && (
        <div class="content-beta__actions">
          {buttons.map(b => <a href={b.content_beta_button_url} class="btn btn--primary">{b.content_beta_button_text}</a>)}
        </div>
      )}
    </div>
  </div>
</section>
<style>
  .content-beta__grid { display: grid; gap: 32px; grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 768px) { .content-beta__grid { grid-template-columns: 1fr 1fr; } }
  .content-beta__image { width: 100%; height: auto; border-radius: 12px; }
  .content-beta__intro { opacity: 0.85; }
  .content-beta__body { line-height: 1.7; }
  .content-beta__actions { display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap; }
</style>
