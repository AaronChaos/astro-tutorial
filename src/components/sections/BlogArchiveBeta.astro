---
/** BlogArchiveBeta — `blog_archive_beta`. Compact list (no images). */
import { wp } from '../../lib/wp';
import type { BlogArchiveBetaSection } from '../../lib/wp';
interface Props { data: BlogArchiveBetaSection; }
const { data } = Astro.props;
const posts = await wp.getPosts({ limit: 24 });
---
<section class="section blog-archive-beta">
  <div class="container">
    {data.blog_beta_heading && <h2>{data.blog_beta_heading}</h2>}
    {data.blog_beta_introduction && <p class="blog-archive-beta__intro">{data.blog_beta_introduction}</p>}
    <ul class="blog-archive-beta__list">
      {posts.map(p => (
        <li>
          <a href={`/blog/${p.slug}`}>
            <span set:html={p.title.rendered} />
            <time datetime={p.date}>{new Date(p.date).toLocaleDateString('en-GB')}</time>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
<style>
  .blog-archive-beta__intro { opacity: 0.85; max-width: 640px; margin-bottom: 24px; }
  .blog-archive-beta__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .blog-archive-beta__list li { border-bottom: 1px solid rgba(255,255,255,0.08); }
  .blog-archive-beta__list a { display: flex; justify-content: space-between; gap: 16px; padding: 14px 0; color: inherit; text-decoration: none; }
  .blog-archive-beta__list a:hover { opacity: 0.85; }
  .blog-archive-beta__list time { opacity: 0.6; font-size: 0.9rem; flex-shrink: 0; }
</style>
