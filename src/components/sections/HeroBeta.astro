---
/** HeroBeta — `hero_beta`. Same shape as alpha; left-aligned variant. */
import type { HeroBetaSection, WpImage } from '../../lib/wp';
interface Props { data: HeroBetaSection; }
const { data } = Astro.props;
const bg = data.hero_beta_background_image as WpImage | null | undefined;
const bgUrl = bg && typeof bg === 'object' ? bg.url : null;
const buttons = data.hero_beta_cta_buttons ?? [];
---
<section
  class="section hero hero-beta"
  style={bgUrl
    ? `background-image: linear-gradient(90deg, rgba(11,11,15,0.85), rgba(11,11,15,0.4)), url('${bgUrl}'); background-size: cover; background-position: center;`
    : undefined}
>
  <div class="container hero-beta__inner">
    {data.hero_beta_heading && <h1>{data.hero_beta_heading}</h1>}
    {data.hero_beta_introduction && <p class="hero-beta__lead">{data.hero_beta_introduction}</p>}
    {data.hero_beta_show_cta_section && (
      <div class="hero-beta__cta">
        {data.hero_beta_cta_heading && <h2>{data.hero_beta_cta_heading}</h2>}
        {data.hero_beta_cta_introduction && <p>{data.hero_beta_cta_introduction}</p>}
        {buttons.length > 0 && (
          <div class="hero-beta__actions">
            {buttons.map(b => (
              <a href={b.hero_beta_button_url} class="btn btn--primary">{b.hero_beta_cta_button_text}</a>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</section>
<style>
  .hero-beta { padding: 100px 0; color: #fff; }
  .hero-beta__inner { max-width: 640px; }
  .hero-beta h1 { margin: 0 0 16px; font-size: clamp(2rem, 5vw, 3rem); }
  .hero-beta__lead { font-size: 1.1rem; opacity: 0.9; }
  .hero-beta__cta { margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.15); }
  .hero-beta__actions { display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap; }
</style>
