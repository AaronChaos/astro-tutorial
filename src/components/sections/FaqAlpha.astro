---
/**
 * FaqAlpha — `faq_alpha` ACF layout.
 * Renders Q&A list AND emits JSON-LD FAQ schema for SEO (rich snippets in Google).
 */
import type { FaqAlphaSection, AcfColor } from '../../lib/wp';
interface Props { data: FaqAlphaSection; }
const { data } = Astro.props;

const bgRaw = data.faq_alpha_background_colour;
const bg = typeof bgRaw === 'string' ? bgRaw : (bgRaw as AcfColor | undefined)?.color;
const items = data.faq_alpha_qanda ?? [];

const faqSchema = items.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(i => ({
    '@type': 'Question',
    name: i.faq_alpha_faq_question,
    acceptedAnswer: { '@type': 'Answer', text: i.faq_alpha_faq_answer },
  })),
} : null;
---
<section class="section faq-alpha" style={bg ? `background: ${bg};` : undefined}>
  <div class="container faq-alpha__inner">
    {data.faq_alpha_heading && <h2>{data.faq_alpha_heading}</h2>}
    {data.faq_alpha_introduction && <p class="faq-alpha__intro">{data.faq_alpha_introduction}</p>}
    {items.length > 0 && (
      <div class="faq-alpha__list">
        {items.map(i => (
          <details class="faq-alpha__item">
            <summary>{i.faq_alpha_faq_question}</summary>
            <p>{i.faq_alpha_faq_answer}</p>
          </details>
        ))}
      </div>
    )}
  </div>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
</section>

<style>
  .faq-alpha__inner { max-width: 760px; margin: 0 auto; }
  .faq-alpha__intro { opacity: 0.85; margin-bottom: 24px; }
  .faq-alpha__list { margin-top: 16px; }
  .faq-alpha__item {
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .faq-alpha__item summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }
  .faq-alpha__item summary::-webkit-details-marker { display: none; }
  .faq-alpha__item summary::after { content: ' +'; opacity: 0.5; }
  .faq-alpha__item[open] summary::after { content: ' −'; }
  .faq-alpha__item p { margin: 12px 0 0; opacity: 0.85; line-height: 1.6; }
</style>
