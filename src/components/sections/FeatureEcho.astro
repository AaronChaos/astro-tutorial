---
/** FeatureEcho — `feature_echo`. Icon-based feature cards in a left-aligned grid. */
import type { FeatureEchoSection, AcfColor } from '../../lib/wp';
interface Props { data: FeatureEchoSection; }
const { data } = Astro.props;
const bgRaw = data.feature_echo_background_colour;
const bg = typeof bgRaw === 'string' ? bgRaw : (bgRaw as AcfColor | undefined)?.color;
const cardRaw = data.feature_echo_card_background_colour;
const cardBg = typeof cardRaw === 'string' ? cardRaw : (cardRaw as AcfColor | undefined)?.color;
const blocks = data.feature_echo_block ?? [];
---
<section class="section feature-echo" style={bg ? `background: ${bg};` : undefined}>
  <div class="container">
    <header class="feature-echo__head">
      {data.feature_echo_heading && <h2>{data.feature_echo_heading}</h2>}
      {data.feature_echo_introduction && <p>{data.feature_echo_introduction}</p>}
    </header>
    {blocks.length > 0 && (
      <div class="feature-echo__grid">
        {blocks.map(b => (
          <article class="feature-echo__card" style={cardBg ? `background: ${cardBg};` : undefined}>
            {b.feature_echo_block_icon && <span class="feature-echo__icon" aria-hidden="true">{b.feature_echo_block_icon}</span>}
            {b.feature_echo_block_heading && <h3>{b.feature_echo_block_heading}</h3>}
            {b.feature_echo_block_main_content && <p>{b.feature_echo_block_main_content}</p>}
          </article>
        ))}
      </div>
    )}
  </div>
</section>
<style>
  .feature-echo__head { max-width: 640px; margin-bottom: 32px; }
  .feature-echo__grid { display: grid; gap: 16px; grid-template-columns: 1fr; }
  @media (min-width: 768px) { .feature-echo__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .feature-echo__grid { grid-template-columns: repeat(4, 1fr); } }
  .feature-echo__card { background: rgba(255,255,255,0.04); padding: 24px; border-radius: 12px; }
  .feature-echo__icon { font-size: 1.75rem; display: inline-block; margin-bottom: 12px; }
  .feature-echo__card h3 { margin: 0 0 6px; font-size: 1.05rem; }
  .feature-echo__card p { margin: 0; opacity: 0.85; line-height: 1.5; }
</style>
