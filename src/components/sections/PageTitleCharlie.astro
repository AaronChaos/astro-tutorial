---
/** PageTitleCharlie — `page_title_charlie`. Background-image variant with overlay. */
import type { PageTitleCharlieSection, WpImage } from '../../lib/wp';
interface Props { data: PageTitleCharlieSection; }
const { data } = Astro.props;
const bg = data.page_title_charlie_background_image as WpImage | null | undefined;
const bgUrl = bg && typeof bg === 'object' ? bg.url : null;
---
<section
  class="section page-title page-title-charlie"
  style={bgUrl
    ? `background-image: linear-gradient(180deg, rgba(11,11,15,0.55), rgba(11,11,15,0.85)), url('${bgUrl}'); background-size: cover; background-position: center;`
    : undefined}
>
  <div class="container">
    {data.page_title_charlie_heading && <h1>{data.page_title_charlie_heading}</h1>}
    {data.page_title_charlie_breadcrumbs && (
      <nav class="page-title__crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>{data.page_title_charlie_heading}</span>
      </nav>
    )}
  </div>
</section>
<style>
  .page-title-charlie { padding: 100px 0 80px; text-align: center; color: #fff; }
  .page-title-charlie h1 { margin: 0; font-size: clamp(2rem, 5vw, 3rem); }
  .page-title-charlie .page-title__crumbs { margin-top: 12px; opacity: 0.85; font-size: 0.95rem; }
  .page-title-charlie .page-title__crumbs a { color: inherit; text-decoration: none; }
</style>
