---
/** FeatureDelta — `feature_delta`. Icon-based feature cards with intro. */
import type { FeatureDeltaSection, AcfColor } from '../../lib/wp';
interface Props { data: FeatureDeltaSection; }
const { data } = Astro.props;
const bgRaw = data.feature_delta_background_colour;
const bg = typeof bgRaw === 'string' ? bgRaw : (bgRaw as AcfColor | undefined)?.color;
const containerRaw = data.feature_delta_container_background_colour;
const containerBg = typeof containerRaw === 'string' ? containerRaw : (containerRaw as AcfColor | undefined)?.color;
const cardRaw = data.feature_delta_card_background_colour;
const cardBg = typeof cardRaw === 'string' ? cardRaw : (cardRaw as AcfColor | undefined)?.color;
const blocks = data.feature_delta_block ?? [];
---
<section class="section feature-delta" style={bg ? `background: ${bg};` : undefined}>
  <div class="container">
    <div class="feature-delta__panel" style={containerBg ? `background: ${containerBg};` : undefined}>
      <header class="feature-delta__head">
        {data.feature_delta_heading && <h2>{data.feature_delta_heading}</h2>}
        {data.feature_delta_introduction && <p>{data.feature_delta_introduction}</p>}
      </header>
      {blocks.length > 0 && (
        <div class="feature-delta__grid">
          {blocks.map(b => (
            <article class="feature-delta__card" style={cardBg ? `background: ${cardBg};` : undefined}>
              {b.feature_delta_block_icon && <span class="feature-delta__icon" aria-hidden="true">{b.feature_delta_block_icon}</span>}
              {b.feature_delta_block_heading && <h3>{b.feature_delta_block_heading}</h3>}
              {b.feature_delta_block_main_content && <p>{b.feature_delta_block_main_content}</p>}
            </article>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
<style>
  .feature-delta__panel { padding: 32px; border-radius: 16px; }
  .feature-delta__head { text-align: center; max-width: 640px; margin: 0 auto 32px; }
  .feature-delta__grid { display: grid; gap: 16px; grid-template-columns: 1fr; }
  @media (min-width: 768px) { .feature-delta__grid { grid-template-columns: repeat(3, 1fr); } }
  .feature-delta__card { background: rgba(255,255,255,0.04); padding: 24px; border-radius: 12px; text-align: center; }
  .feature-delta__icon { font-size: 2rem; display: inline-block; margin-bottom: 12px; }
  .feature-delta__card h3 { margin: 0 0 6px; font-size: 1.05rem; }
  .feature-delta__card p { margin: 0; opacity: 0.85; line-height: 1.5; }
</style>
