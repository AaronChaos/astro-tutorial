---
/** CtaAlpha — `cta_alpha` ACF layout. Heading + intro + buttons over a background image. */
import type { CtaAlphaSection, WpImage } from '../../lib/wp';
interface Props { data: CtaAlphaSection; }
const { data } = Astro.props;

const bg = data.cta_alpha_image as WpImage | null | undefined;
const bgUrl = bg && typeof bg === 'object' ? bg.url : null;
const buttons = data.cta_alpha_cta_buttons ?? [];
---
<section
  class="section cta-alpha"
  style={bgUrl
    ? `background-image: linear-gradient(180deg, rgba(11,11,15,0.55), rgba(11,11,15,0.85)), url('${bgUrl}'); background-size: cover; background-position: center;`
    : undefined}
>
  <div class="container cta-alpha__inner">
    {data.cta_alpha_heading && <h2>{data.cta_alpha_heading}</h2>}
    {data.cta_alpha_introduction && <p class="cta-alpha__intro">{data.cta_alpha_introduction}</p>}
    {buttons.length > 0 && (
      <div class="cta-alpha__actions">
        {buttons.map(b => (
          <a href={b.cta_alpha_button_url} class="btn btn--primary">{b.cta_alpha_button_text}</a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .cta-alpha { padding: 80px 0; text-align: center; color: #fff; }
  .cta-alpha__inner { max-width: 640px; margin: 0 auto; }
  .cta-alpha__intro { font-size: 1.1rem; opacity: 0.9; margin: 16px 0 24px; }
  .cta-alpha__actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
</style>
