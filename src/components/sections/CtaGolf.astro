---
/** CtaGolf — `cta_golf`. Full-width background image hero CTA with overlay tint. */
import type { CtaGolfSection, WpImage, AcfColor } from '../../lib/wp';
interface Props { data: CtaGolfSection; }
const { data } = Astro.props;
const img = data.cta_golf_background_image as WpImage | null | undefined;
const imgUrl = img && typeof img === 'object' ? img.url : null;
const overlayRaw = data.cta_golf_overlay_colour;
const overlayColor = typeof overlayRaw === 'string' ? overlayRaw : (overlayRaw as AcfColor | undefined)?.color;
const overlay = overlayColor || 'rgba(11,11,15,0.7)';
---
<section
  class="section cta-golf"
  style={imgUrl
    ? `background-image: linear-gradient(180deg, ${overlay}, ${overlay}), url('${imgUrl}'); background-size: cover; background-position: center;`
    : undefined}
>
  <div class="container cta-golf__inner">
    {data.cta_golf_heading && <h2>{data.cta_golf_heading}</h2>}
    {data.cta_golf_introduction && <p>{data.cta_golf_introduction}</p>}
    {data.cta_golf_button_text && data.cta_golf_button_url && (
      <a href={data.cta_golf_button_url} class="btn btn--primary">{data.cta_golf_button_text}</a>
    )}
  </div>
</section>
<style>
  .cta-golf { padding: 100px 0; text-align: center; color: #fff; }
  .cta-golf__inner { max-width: 720px; margin: 0 auto; }
  .cta-golf h2 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 16px; }
  .cta-golf p { font-size: 1.1rem; opacity: 0.9; margin-bottom: 24px; }
</style>
