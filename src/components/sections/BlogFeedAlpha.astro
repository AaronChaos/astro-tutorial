---
/** BlogFeedAlpha — `blog_feed_alpha`. Latest 3 posts as cards. */
import { wp } from '../../lib/wp';
import type { BlogFeedAlphaSection, AcfColor } from '../../lib/wp';
interface Props { data: BlogFeedAlphaSection; }
const { data } = Astro.props;
const bgRaw = data.blog_feed_alpha_background_colour;
const bg = typeof bgRaw === 'string' ? bgRaw : (bgRaw as AcfColor | undefined)?.color;
const posts = await wp.getPosts({ limit: 3 });
---
<section class="section blog-feed-alpha" style={bg ? `background: ${bg};` : undefined}>
  <div class="container">
    {data.blog_feed_alpha_heading && <h2>{data.blog_feed_alpha_heading}</h2>}
    {data.blog_feed_introduction && <p class="blog-feed-alpha__intro">{data.blog_feed_introduction}</p>}
    <div class="blog-feed-alpha__grid">
      {posts.map(p => (
        <a class="blog-feed-alpha__card" href={`/blog/${p.slug}`}>
          {p.featured_image && <img src={p.featured_image.url} alt={p.featured_image.alt} loading="lazy" />}
          <div class="blog-feed-alpha__body">
            <h3 set:html={p.title.rendered} />
            <p class="blog-feed-alpha__excerpt" set:html={p.excerpt.rendered} />
            <time datetime={p.date}>{new Date(p.date).toLocaleDateString('en-GB')}</time>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
<style>
  .blog-feed-alpha__intro { opacity: 0.85; max-width: 640px; margin-bottom: 32px; }
  .blog-feed-alpha__grid { display: grid; gap: 20px; grid-template-columns: 1fr; }
  @media (min-width: 768px) { .blog-feed-alpha__grid { grid-template-columns: repeat(3, 1fr); } }
  .blog-feed-alpha__card { display: block; text-decoration: none; color: inherit; background: rgba(255,255,255,0.04); border-radius: 12px; overflow: hidden; }
  .blog-feed-alpha__card img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }
  .blog-feed-alpha__body { padding: 20px; }
  .blog-feed-alpha__body h3 { margin: 0 0 8px; font-size: 1.1rem; }
  .blog-feed-alpha__excerpt { margin: 0 0 8px; opacity: 0.85; line-height: 1.5; font-size: 0.95rem; }
  .blog-feed-alpha__body time { opacity: 0.6; font-size: 0.85rem; }
</style>
