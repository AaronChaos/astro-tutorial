---
/**
 * ContentAlpha — mirrors the `content_alpha` ACF flexible content layout.
 * Two-column layout: text + image, with optional CTA buttons.
 */
import type { ContentAlphaSection, WpImage, AcfColor } from '../../lib/wp';

interface Props { data: ContentAlphaSection; }

const { data } = Astro.props;

const img = data.content_alpha_image as WpImage | null | undefined;
const imgUrl = img && typeof img === 'object' ? img.url : null;
const imgAlt = img && typeof img === 'object' ? img.alt : '';

// background_colour can come as a hex string or as an ACF color object.
const bgRaw = data.content_alpha_background_colour;
const bg = typeof bgRaw === 'string'
  ? bgRaw
  : (bgRaw as AcfColor | undefined)?.color;

const buttons = data.content_alpha_cta_buttons ?? [];
---
<section class="section content-alpha" style={bg ? `background: ${bg};` : undefined}>
  <div class="container content-alpha__inner">
    <div class="content-alpha__text">
      {data.content_alpha_heading && <h2>{data.content_alpha_heading}</h2>}
      {data.content_alpha_introduction && (
        <p class="content-alpha__intro">{data.content_alpha_introduction}</p>
      )}
      {data.content_alpha_main_content && (
        <p class="content-alpha__body">{data.content_alpha_main_content}</p>
      )}
      {buttons.length > 0 && (
        <div class="content-alpha__actions">
          {buttons.map(b => (
            <a href={b.content_alpha_button_url} class="btn btn--primary">
              {b.content_alpha_button_text}
            </a>
          ))}
        </div>
      )}
    </div>
    {imgUrl && (
      <div class="content-alpha__media">
        <img src={imgUrl} alt={imgAlt} loading="lazy" />
      </div>
    )}
  </div>
</section>

<style>
  .content-alpha__inner {
    display: grid;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .content-alpha__inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  .content-alpha__intro {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 16px;
  }
  .content-alpha__body { line-height: 1.7; }
  .content-alpha__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .content-alpha__media img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
  }
</style>
